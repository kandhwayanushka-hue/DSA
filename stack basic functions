#include <iostream>
using namespace std;

class Stack{
    int *arr;
    int size;
    int top;
    public:
    Stack (int S)
    {
        size=S;
        top=-1;
        arr= new int[S];
    }
    void push (int value){
        if (top==size-1){
            cout<<"stack overflow"<<endl;;
        }
        else {
            top++;
            arr[top]=value;
            cout<<value<<"inserted in stack"<<endl;
        }
    }
    void pop(){
        if (top==-1){
            cout<<"stack overflow"<<endl;;
            return;
        }
        else{
            int value=arr[top];
            top--;
            cout<<"popped"<<value<<"from the stack"<<endl;;
        }
    }
    int peek(){
        if (top==-1){
            cout<<"stack empty"<<endl;
            return -1;
        }
        else{
            return arr[top];
        }
    }
    bool IsEmpty(){
        return top==-1;
    }
    int IsSize(){
        return top+1;
    }
};

int main() {
    Stack s(17);
    s.push(5);
    s.push(7);
    s.push(4);
    s.pop();
    cout<<s.peek()<<endl;
    cout<<s.IsEmpty()<<endl;
    cout<<s.IsSize()<<endl;

    return 0;
}
