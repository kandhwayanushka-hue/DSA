Q Call by value function 

#include <iostream>
using namespace std;

void CallByValue(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
    cout << a << " " << b << endl;
}

int main() {
    int x = 2, y = 3;
    CallByValue(x, y);
    cout << x << " " << y; // original unchanged
    return 0;
}

Q.Call by reference

#include <iostream>
using namespace std;


void CallByReference(int& a){
    a--;
}
int main(){
    int a;
    cout<<"Enter the value";
    cin>>a;
    CallByReference(a);
    cout<<a<<endl;
}

#include <iostream>
using namespace std;

void CallByReference(int &a, int &b) {
    int temp = a;
    a = b;
    b = temp;
}

int main() {
    int x = 2, y = 3;
    cout << "Before: " << x << " " << y << endl;
    CallByReference(x, y);
    cout << "After: " << x << " " << y << endl;
    return 0;
}


Q call by reference and call by address function 
 #include <iostream>
#include <cmath>
using namespace std;
void CallByAddress(int *a ,int *b){
    int temp=*a;
    *a=*b;
    *b=temp;
    cout<<*a<<" "<<*b<<endl;
}
void square(int a,int *b){
    *b=a*a;
}
void CallByReference(int &a, int &b){
    int temp=a;
    a=b;
    b=temp;
    cout<<a<<" "<<b<<endl;
}
int main(){
    int a,b;
    cout<<"Enter the digits";
    cin>>a>>b;
    cout<<"After swapping the digits by call by address are"<<endl;
    CallByAddress(&a,&b);
    cout<<"After wapping the digits by call by reference are"<<endl;
    CallByReference(a,b);
    cout<<"the double is"<<endl;
    square(a,&b);
    cout<<b;
    return 0;
    
}




