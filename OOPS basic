Q Make a class that inputss students name marks and then finds the average of it 

#include <iostream>
#include <string>
using namespace std;

class studentInfo {
private:
    int n;
    string b;
    double c;
    int marks[100]; // array to store marks
public:
    void inputData() {
        cout << "Name of the student: ";
        cin >> b;
        cout << "Enter the number of subjects: ";
        cin >> n;
        int sum = 0;
        for (int i = 0; i < n; i++) {
            cout << "Enter marks for subject " << i + 1 << ": ";
            cin >> marks[i];
            sum += marks[i];
        }
        c = (double)sum / n;
    }
    void outputData() {
        cout << "Name of student: " << b << endl;
        for (int i = 0; i < n; i++) {
            cout << "Marks in subject " << i + 1 << ": " << marks[i] << endl;
        }
        cout << "Average: " << c << endl;
    }
};

int main() {
    studentInfo s1;
    s1.inputData();
    s1.outputData();
    return 0;
}


