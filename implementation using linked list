#include <iostream>
#include <stack>
using namespace std;

class Node{
    public:
    int data;
    Node *next;
        Node(int value){
            data=value;
            next=NULL;
        }
};
class Stack{
    int size;
    Node *top;
    public:
    Stack(){
        size=0;
        top=NULL;
    }
    void push(int value){
        Node *temp=new Node(value);
        if (temp==NULL){
            cout<<"stack overflow";
            return;
        }
        temp->next=top;
        top=temp;
        size++;
        cout<<value<<"pushed in the stack"<<endl;
    }
};
int main(){
    Stack s;
    s.push(10);
    s.push(20);
    return 0;
}
